# Backend environment — copy to .env and fill values.
# Use the SAME Supabase Postgres connection string as the frontend DB.
# Supabase dashboard → Project Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres:[REDACTED]@db.whonozmzgildsxrzsopp.supabase.co:5432/postgres

# Service role key (server-only, bypasses RLS) — from Supabase dashboard.
SUPABASE_URL=https://whonozmzgildsxrzsopp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=[REDACTED]

# Public anon key (for client-side verification of JWTs if needed).
SUPABASE_ANON_KEY=[REDACTED]

PORT=4000

# Optional Redis (Railway Redis). Leave blank to skip caching.
REDIS_URL=

# Optional SMTP fallback (Nodemailer).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
