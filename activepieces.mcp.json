{
  "mcpServers": {
    "activepieces-zertech": {
      "url": "https://cloud.activepieces.com/mcp/sse",
      "description": "ActivePieces MCP - manage flows and connect to Zertech",
      "auth": {
        "type": "bearer",
        "token": "${ACTIVE_PIECES_API_KEY}"
      },
      "tools": [
        {
          "name": "list_flows",
          "description": "List all ActivePieces flows"
        },
        {
          "name": "run_flow",
          "description": "Run an ActivePieces flow"
        }
      ]
    }
  },
  "connections": {
    "zertech": {
      "webhook": {
        "url": "http://localhost:8080/api/automation/webhook",
        "triggers": "http://localhost:8080/api/automation/triggers",
        "actions": "http://localhost:8080/api/automation/actions"
      }
    }
  }
}